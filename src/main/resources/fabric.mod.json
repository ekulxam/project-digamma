			"gdn.hypercube.digamma.init.DigammaProjectLoader"
		],
		"client": [
          "gdn.hypercube.digamma.delta.core.DeltaProtocolBootSequence"
		],
		"cardinal-components": [
			"gdn.hypercube.digamma.init.DigammaProjectLoader"
		],
		"fabric-datagen": [
			"gdn.hypercube.digamma.data.DigammaDatagen"
		]
	},
	"mixins": [
      "digamma-development.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*",
		"solaris": "*"
	},
	"accessWidener": "digamma.classtweaker",
	"custom": {
		"cardinal-components": [
			"digamma:flags"
		]
	}
}