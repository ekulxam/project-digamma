{
	"schemaVersion": 1,
	"id": "digamma",
	"version": "${version}",
	"name": "Digamma Project",
	"description": "ϝ",
	"authors": [
		"LilyflowerFDL"
	],
	"contact": {
		"homepage": "https://hypercube.gdn/digamma",
		"sources": "https://github.com/AutumnalModding/DigammaProject"
	},
	"license": "GPLv3",
	"icon": "assets/digamma/icon.png",
	"environment": "*",
	"entrypoints": {
		"preLaunch": [
			"gdn.hypercube.digamma.init.SolarisIntegrator"
		],
